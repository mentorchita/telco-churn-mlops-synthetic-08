# =============================================================================
# .env.example
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it's in .gitignore
# =============================================================================

# ── Application ──────────────────────────────────────────────
MODEL_NAME=churn-model
MODEL_STAGE=Production
MODEL_VERSION=v1.2
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── API ──────────────────────────────────────────────────────
# Set to true for Demo 4 (latency spike injection)
INJECT_LATENCY=false
# Fraction of traffic to route to candidate model (Demo 8 A/B)
AB_SPLIT=0.0

# ── Grafana ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=mlops_pass
GF_SECURITY_SECRET_KEY=change_me_in_production_use_random_32chars

# ── Alertmanager: Slack ───────────────────────────────────────
# Create webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK
SLACK_CHANNEL_GENERAL=#mlops-alerts
SLACK_CHANNEL_CRITICAL=#mlops-critical
SLACK_CHANNEL_ML_TEAM=#ml-model-health

# ── Alertmanager: Email (optional) ───────────────────────────
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=mlops-alerts@yourcompany.com
SMTP_USER=mlops-alerts@yourcompany.com
# Use Gmail App Password (not your main password):
# https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_gmail_app_password_here
ALERT_EMAIL_TO=ml-team@yourcompany.com

# ── Alertmanager: PagerDuty (optional) ───────────────────────
# Integration key from PagerDuty → Services → Integrations → Prometheus
PAGERDUTY_ROUTING_KEY=your_pagerduty_integration_key_here

# ── Drift Detection ───────────────────────────────────────────
PUSHGATEWAY_URL=http://localhost:9091
REFERENCE_DATA_PATH=data/reference/
LIVE_DATA_PATH=data/live/

# ── Kubernetes (k3s) ─────────────────────────────────────────
K8S_NAMESPACE_MONITORING=monitoring
K8S_NAMESPACE_APP=mlops
HELM_CHART_VERSION=55.5.0
